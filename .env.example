# Environment Variables — Visual Podcast Companion
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is in .gitignore.

# ---------------------------------------------------------------
# OpenRouter API Key
# Sign up and get your key at: https://openrouter.ai/
# ---------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------
# LLM Model Slug (from OpenRouter Models Catalog)
# Use the exact slug — e.g. from https://openrouter.ai/models
# To switch models, change this one line. No code changes needed.
# ---------------------------------------------------------------
LLM_MODEL=google/gemini-2.5-flash-lite
