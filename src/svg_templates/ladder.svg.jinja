<svg viewBox="0 0 180 96" xmlns="http://www.w3.org/2000/svg" style="background:var(--surf2);border-radius:6px;display:block;width:100%;height:96px">
  <!-- Side rails -->
  <line x1="14" y1="8" x2="14" y2="90" stroke="#888" stroke-width="1.5"/>
  <line x1="166" y1="8" x2="166" y2="90" stroke="#888" stroke-width="1.5"/>

  <!-- Tiers (Rungs/Steps) -->
  {% for tier in tiers[:3] %}
  {% set rect_w = [152, 120, 88][loop.index0] %}
  {% set rect_x = [14, 30, 46][loop.index0] %}
  {% set rect_y = [70, 44, 18][loop.index0] %}
  
  <rect x="{{ rect_x }}" y="{{ rect_y }}" width="{{ rect_w }}" height="18" rx="3" fill="{{ tier.color or accentColor }}" opacity=".85"/>
  <text x="90" y="{{ rect_y + 11 }}" text-anchor="middle" font-size="7" fill="#fff" font-weight="bold">{{ tier.name }}</text>
  <text x="90" y="{{ rect_y - 2 }}" text-anchor="middle" font-size="5.5" fill="{{ tier.color or accentColor }}">{{ tier.desc }}</text>
  {% endfor %}
</svg>
