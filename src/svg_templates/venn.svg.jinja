<svg viewBox="0 0 180 96" xmlns="http://www.w3.org/2000/svg" style="background:var(--surf2);border-radius:6px;display:block;width:100%;height:96px">
  <!-- Left Circle -->
  <circle cx="62" cy="52" r="33" fill="{{ accentColor }}" opacity=".15" stroke="{{ accentColor }}" stroke-width="1.5"/>
  <text x="44" y="52" text-anchor="middle" font-size="7.5" fill="{{ accentColor }}" font-weight="bold">{{ left.title }}</text>
  <text x="44" y="62" text-anchor="middle" font-size="6" fill="#888">{{ left.label }}</text>

  <!-- Right Circle -->
  <circle cx="118" cy="52" r="33" fill="#7a39bb" opacity=".15" stroke="#7a39bb" stroke-width="1.5"/>
  <text x="136" y="52" text-anchor="middle" font-size="7.5" fill="#7a39bb" font-weight="bold">{{ right.title }}</text>
  <text x="136" y="62" text-anchor="middle" font-size="6" fill="#888">{{ right.label }}</text>

  <!-- Top Circle -->
  <circle cx="90" cy="32" r="22" fill="#da7101" opacity=".2" stroke="#da7101" stroke-width="1.5"/>
  <text x="90" y="24" text-anchor="middle" font-size="6.5" fill="#da7101" font-weight="bold">{{ top.title }}</text>
  <text x="90" y="32" text-anchor="middle" font-size="5" fill="#888">{{ top.label }}</text>

  <!-- Center intersection content -->
  {% for text_line in center %}
  <text x="90" y="{{ 58 + loop.index0 * 8 }}" text-anchor="middle" font-size="6" fill="#888" font-weight="bold">{{ text_line }}</text>
  {% endfor %}
</svg>
