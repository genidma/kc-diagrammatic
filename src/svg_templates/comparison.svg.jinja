<svg viewBox="0 0 180 96" xmlns="http://www.w3.org/2000/svg" style="background:var(--surf2);border-radius:6px;display:block;width:100%;height:96px">
  <!-- Left Side Box -->
  <rect x="4" y="4" width="80" height="86" rx="5" fill="{{ accentColor }}" opacity=".1" stroke="{{ accentColor }}" stroke-width="1"/>
  <rect x="4" y="4" width="80" height="14" rx="5" fill="{{ accentColor }}" opacity=".7"/>
  <text x="44" y="14" text-anchor="middle" font-size="7" fill="#fff" font-weight="bold">{{ left.title }}</text>
  <text x="44" y="32" text-anchor="middle" font-size="14">{{ left.icon or '📄' }}</text>
  
  {% for line in left.lines[:3] %}
  <text x="44" y="{{ 45 + loop.index0 * 9 }}" text-anchor="middle" font-size="6" fill="#888">{{ line }}</text>
  {% endfor %}
  <text x="44" y="83" text-anchor="middle" font-size="6" fill="{{ accentColor }}" font-weight="bold">{{ left.footer }}</text>

  <!-- Right Side Box -->
  <rect x="96" y="4" width="80" height="86" rx="5" fill="#006494" opacity=".1" stroke="#006494" stroke-width="1"/>
  <rect x="96" y="4" width="80" height="14" rx="5" fill="#006494" opacity=".7"/>
  <text x="136" y="14" text-anchor="middle" font-size="7" fill="#fff" font-weight="bold">{{ right.title }}</text>
  <text x="136" y="32" text-anchor="middle" font-size="14">{{ right.icon or '💻' }}</text>

  {% for line in right.lines[:3] %}
  <text x="136" y="{{ 45 + loop.index0 * 9 }}" text-anchor="middle" font-size="6" fill="#888">{{ line }}</text>
  {% endfor %}
  <text x="136" y="83" text-anchor="middle" font-size="6" fill="#006494" font-weight="bold">{{ right.footer }}</text>
</svg>
