<svg viewBox="0 0 180 96" xmlns="http://www.w3.org/2000/svg" style="background:var(--surf2);border-radius:6px;display:block;width:100%;height:96px">
  <!-- Root Node -->
  <rect x="55" y="4" width="70" height="14" rx="3" fill="{{ accentColor }}" opacity=".85"/>
  <text x="90" y="14" text-anchor="middle" font-size="7.5" fill="#fff" font-weight="bold">{{ root }}</text>

  <!-- Connectors -->
  <line x1="90" y1="18" x2="90" y2="26" stroke="{{ accentColor }}" stroke-width="1"/>
  <line x1="22" y1="26" x2="158" y2="26" stroke="{{ accentColor }}" stroke-width="1"/>
  <line x1="22" y1="26" x2="22" y2="32" stroke="{{ accentColor }}" stroke-width="1"/>
  <line x1="68" y1="26" x2="68" y2="32" stroke="{{ accentColor }}" stroke-width="1"/>
  <line x1="112" y1="26" x2="112" y2="32" stroke="{{ accentColor }}" stroke-width="1"/>
  <line x1="158" y1="26" x2="158" y2="32" stroke="{{ accentColor }}" stroke-width="1"/>

  <!-- Children Nodes -->
  {% for child in children[:4] %}
  {% set x_pos = [5, 51, 95, 141][loop.index0] %}
  <rect x="{{ x_pos }}" y="32" width="34" height="16" rx="2" fill="{{ accentColor }}" opacity=".65"/>
  <text x="{{ x_pos + 17 }}" y="43" text-anchor="middle" font-size="6.5" fill="#fff">{{ child }}</text>
  {% endfor %}

  <!-- Sublabels -->
  {% for sublabel in sublabels[:4] %}
  {% set x_pos = [22, 68, 112, 158][loop.index0] %}
  <text x="{{ x_pos }}" y="62" text-anchor="middle" font-size="5.5" fill="{{ accentColor }}">{{ sublabel }}</text>
  {% endfor %}

  <!-- Note -->
  {% if note %}
  <text x="90" y="80" text-anchor="middle" font-size="6" fill="#888">{{ note }}</text>
  {% endif %}
</svg>
