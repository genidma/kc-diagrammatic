<svg viewBox="0 0 180 96" xmlns="http://www.w3.org/2000/svg" style="background:var(--surf2);border-radius:6px;display:block;width:100%;height:96px">
  <!-- Top Polygon (Wide) -->
  <polygon points="10,6 170,6 145,34 35,34" fill="{{ accentColor }}" opacity=".2" stroke="{{ accentColor }}" stroke-width="1.5"/>
  <text x="90" y="24" text-anchor="middle" font-size="8.5" fill="{{ accentColor }}" font-weight="bold">{{ stages[0] }}</text>

  <!-- Middle Polygon -->
  <polygon points="35,36 145,36 125,62 55,62" fill="{{ accentColor }}" opacity=".45" stroke="{{ accentColor }}" stroke-width="1.5"/>
  <text x="90" y="52" text-anchor="middle" font-size="7.5" fill="#888" font-weight="bold">{{ stages[1] }}</text>

  <!-- Bottom Polygon (Narrow) -->
  <polygon points="55,64 125,64 105,86 75,86" fill="{{ accentColor }}" opacity=".8" stroke="{{ accentColor }}" stroke-width="1.5"/>
  <text x="90" y="78" text-anchor="middle" font-size="8.5" fill="#fff" font-weight="bold">{{ stages[2] }}</text>
</svg>
